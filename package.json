{
  "name": "coursebook-backend",
  "version": "1.0.0",
  "description": "Backend + data layer for the Coursebook course & payment tracker (one family per account).",
  "type": "module",
  "private": true,
  "engines": { "node": ">=22.5.0" },
  "scripts": {
    "start": "node --experimental-sqlite src/server.js",
    "dev": "node --experimental-sqlite --watch src/server.js",
    "migrate": "node --experimental-sqlite src/db/migrate.js",
    "test": "node --experimental-sqlite test/smoke.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  }
}
